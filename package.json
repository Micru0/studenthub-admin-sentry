    "ionic:serve:khalid": "ionic serve --configuration=khalid",
    "sentry:prebuild": "node scripts/sentry-prebuild.js",
    "sentry:postbuild": "node scripts/sentry-postbuild.js",
    "sentry:sourcemaps": "npm run sentry:postbuild"
  },
