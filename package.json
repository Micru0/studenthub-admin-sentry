  "scripts": {
    "ng": "ng",
    "prebuild": "npm run sentry:prebuild",
    "start": "ng serve",
    "build": "ng build",
    "postbuild": "npm run sentry:postbuild",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
